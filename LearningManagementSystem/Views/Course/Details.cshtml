@using System.Security.Claims
@model Course
@{
    ViewData["Title"] = "Course Details";
}

<div class="container mt-4">

    <!----------------------------- Course Header Section ------------------------------->
    <div class="p-4 bg-light rounded shadow-sm">

        <h2 class="fw-bold mb-2">@Model.Title</h2>

        <p class="text-muted mb-2">
            @Model.Description
        </p>

        <p class="text-muted mb-2">
            <strong>Total Hours: </strong>
            @Model.duration
        </p>

        <!-- Buttons -->
        @if (User.IsInRole("Instructor"))
        {
            <div class="d-flex flex-wrap gap-2">

                <a asp-controller="Course" asp-action="UpdateCourse" asp-route-id="@Model.Id"
                   class="btn btn-primary">
                    Update Course
                </a>

                <a asp-controller="Course" asp-action="DeleteCourse" asp-route-id="@Model.Id"
                   class="btn btn-danger"
                   onclick="return confirm('Are you sure you want to delete this course?');">
                    Delete Course
                </a>

                <a asp-controller="Lesson" asp-action="CreateLesson" asp-route-courseId="@Model.Id"
                   class="btn btn-success">
                    Add Lesson
                </a>

                <!-- Dropdown -->
                <div class="dropdown">
                    <button class="btn btn-secondary dropdown-toggle" type="button"
                            data-bs-toggle="dropdown">
                        More Actions
                    </button>

                    <ul class="dropdown-menu">
                        <li>
                            <a class="dropdown-item"
                               asp-controller="Enrollment"
                               asp-action="EnrolledStudents"
                               asp-route-courseId=@Model.Id>
                                Enrolled Students
                            </a>
                        </li>

                        <li><hr class="dropdown-divider"></li>

                        <li>
                            <a class="dropdown-item"
                               asp-controller="Assignment"
                               asp-action="CreateAssignment"
                               asp-route-courseId=@Model.Id>
                                Upload Assignment
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item"
                               asp-controller="Quiz"
                               asp-action="CreateQuiz"
                               asp-route-courseId=@Model.Id>
                                Create Quiz
                            </a>
                        </li>

                        <li><hr class="dropdown-divider"></li>

                        <li>
                            <a class="dropdown-item"
                               asp-controller="Question"
                               asp-action="CreateQuestion"
                               asp-route-courseId=@Model.Id>
                                Create Question
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item"
                               asp-controller="Question"
                               asp-action="Index"
                               asp-route-courseId="@Model.Id">
                                View Questions
                            </a>
                        </li>
                    </ul>
                </div>

            </div>
        }
        else if (User.IsInRole("Admin"))
        {
            <a asp-controller="Course" asp-action="DeleteCourse" asp-route-id="@Model.Id"
               class="btn btn-danger"
               onclick="return confirm('Are you sure you want to delete this course?');">
                Delete Course
            </a>
        }

    </div>

    <!--------------------------------- Lessons Section --------------------------->
    <h4 class="mb-3 mt-3">Lessons</h4>

    @if (Model.Lessons == null || !Model.Lessons.Any())
    {
        <div class="alert alert-warning">
            No lessons added yet.
        </div>
    }
    else
    {
        <div class="accordion" id="lessonsAccordion">
            @foreach (var lesson in Model.Lessons)
            {
                <div class="accordion-item mb-2 shadow-sm">
                    <h2 class="accordion-header" id="heading-@lesson.Id">
                        <button class="accordion-button collapsed fw-bold"
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#collapse-@lesson.Id">
                            Lesson: @lesson.Title
                        </button>
                    </h2>

                    <div id="collapse-@lesson.Id"
                         class="accordion-collapse collapse"
                         data-bs-parent="#lessonsAccordion">

                        <div class="accordion-body">

                            <!-- Media Files -->
                            @if (lesson.MediaFiles == null || !lesson.MediaFiles.Any())
                            {
                                <p class="text-muted">No media uploaded.</p>
                            }
                            else
                            {
                                foreach (var media in lesson.MediaFiles)
                                {
                                    <div class="card mb-3 p-3 shadow-sm">

                                        @if (media.MediaType == "video")
                                        {
                                            <video controls class="w-100" style="height:300px;">
                                                <source src="/@media.FilePath" type="video/mp4" />
                                            </video>
                                        }
                                        else if (media.MediaType == "audio")
                                        {
                                            <audio controls class="w-100">
                                                <source src="/@media.FilePath" type="audio/mpeg" />
                                            </audio>
                                        }
                                        else
                                        {
                                            // image or file 
                                            <a href="/@media.FilePath" target="_blank" class="btn btn-outline-primary">
                                                @media.FileName
                                            </a>

                                        }
                                        <!-- Media File Buttons -->
                                        <div class="mt-2 d-flex justify-content-center gap-2">
                                            <!-- Download button -->
                                            <a href="/@media.FilePath" download class="btn btn-sm btn-outline-success">
                                                Download
                                            </a>

                                            <!-- Delete button -->
                                            @if (User.IsInRole("Instructor"))
                                            {
                                                <a asp-controller="Media" asp-action="DeleteMedia" asp-route-mediaId="@media.Id" asp-route-courseId=@Model.Id
                                                   class="btn btn-sm btn-outline-danger"
                                                   onclick="return confirm('Are you sure you want to delete this file?');">
                                                    Delete
                                                </a>
                                            }

                                        </div>

                                    </div>
                                }
                            }

                            <!-- Lesson Buttons -->
                            @if (User.IsInRole("Instructor"))
                            {
                                <div class="mt-3 d-flex justify-content-end">
                                    <a asp-controller="Lesson" asp-action="UpdateLesson" asp-route-lessonId=@lesson.Id
                                       class="btn btn-primary mt-3 me-2">
                                        Update Lesson
                                    </a>

                                    <a asp-controller="Lesson" asp-action="DeleteLesson" asp-route-lessonId=@lesson.Id
                                       class="btn btn-primary mt-3 me-2"
                                       onclick="return confirm('Are you sure you want to delete this lesson?');">
                                        Delete Lesson
                                    </a>

                                    <a asp-controller="Media" asp-action="AddMedia" asp-route-lessonId="@lesson.Id"
                                       class="btn btn-primary mt-3 me-2">
                                        Add File
                                    </a>
                                </div>
                            }


                        </div>
                    </div>
                </div>
            }
        </div>
    }



    <!--------------------------------- Assignments Section --------------------------->
    <h4 class="mb-3 mt-3">Assignments</h4>
    @if (Model.Assignments == null || !Model.Assignments.Any())
    {
        <div class="alert alert-warning">
            No Assignments added yet.
        </div>
    }
    else
    {
        <div class="accordion" id="assignmentsAccordion">
            @foreach (var assignment in Model.Assignments)
            {
                <div class="accordion-item mb-2 shadow-sm">
                    <h2 class="accordion-header" id="heading-@assignment.Id">
                        <button class="accordion-button collapsed fw-bold"
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#collapse-@assignment.Id">
                            Assignment: @assignment.Title
                        </button>
                    </h2>

                    <div id="collapse-@assignment.Id"
                         class="accordion-collapse collapse"
                         data-bs-parent="#assignmentsAccordion">

                        <div class="accordion-body">

                            <!-- Assignment File -->

                            <div class="card mb-3 p-3 shadow-sm">

                                <a href="/@assignment.AssignmentFilePath" target="_blank" class="btn btn-outline-primary">
                                    @assignment.AssignmentFileName
                                </a>
                                        
                                <!-- Assignment File Buttons -->
                                <div class="mt-2 d-flex justify-content-center gap-2">
                                    <!-- Download button -->
                                    <a href="/@assignment.AssignmentFilePath" download class="btn btn-sm btn-outline-success">
                                        Download
                                    </a>
                                </div>

                            </div>
                         
                            <!-- Assignment Buttons -->
                            @if (User.IsInRole("Instructor"))
                            {
                                <div class="mt-3 d-flex justify-content-end">
                                    <a asp-controller="Assignment" asp-action="UpdateAssignment" asp-route-assignmentId=@assignment.Id
                                       class="btn btn-primary mt-3 me-2">
                                        Update Assignment
                                    </a>

                                    <a asp-controller="Assignment" asp-action="DeleteAssignment" asp-route-assignmentId=@assignment.Id
                                       class="btn btn-primary mt-3 me-2"
                                       onclick="return confirm('Are you sure you want to delete this Assignment?');">
                                        Delete Assignment
                                    </a>

                                    <a asp-controller="AssignmentSubmission" asp-action="UncheckedSubmissions" asp-route-assignmentId=@assignment.Id
                                       class="btn btn-primary mt-3 me-2">
                                        Unchecked Submissions
                                    </a>
                                </div>
                             }

                             <!------------------------------ Assignment Submission button  ---------------------->
                            @if (User.IsInRole("Student"))
                            {
                                var studentId = User.FindFirstValue(ClaimTypes.NameIdentifier);

                                var submission = assignment.AssignmentSubmissions
                                .FirstOrDefault(s => s.ApplicationUserId == studentId && s.AssignmentId == assignment.Id);

                                DateTime now = DateTime.Now;

                                <p class="mb-1">
                                    <strong>Start:</strong> @assignment.StartTime.ToString("MMMM dd, yyyy hh:mm tt")
                                </p>

                                <p class="mb-1">
                                    <strong>Deadline:</strong> @assignment.EndTime.ToString("MMMM dd, yyyy hh:mm tt")
                                </p>

                                <p class="mb-3">
                                    <strong>Total Degree:</strong> @assignment.TotalDegree
                                </p>
                                @if (submission!= null && submission.IsChecked)
                                {
                                    <p class="mb-3">
                                        <strong>Your Degree:</strong> @submission.Degree
                                    </p>
                                }

                                <hr />

                                <!-- Submission Status -->
                                @if (submission != null)
                                {
                                    <p class="text-success fw-bold">
                                        <i class="bi bi-check-circle-fill"></i>
                                        Submitted at: @submission.SubmittedAt.ToString("MMMM dd, yyyy hh:mm tt")

                                    </p>

                                    <a href="/@submission.SolutionFilePath" target="_blank" class="btn btn-success btn-sm mb-3">
                                        View YSubmissionour
                                    </a>

                                    <hr />
                                }
                                else if (now < assignment.StartTime)
                                {
                                    <p class="text-warning fw-bold">Assignment Submission not available yet.</p>
                                }
                                else if (now > assignment.EndTime)
                                {
                                    <p class="text-danger fw-bold">🚫 Deadline passed. Upload is closed.</p>
                                }
                                else
                                {
                                    <form asp-controller="AssignmentSubmission" asp-action="AddSubmission"
                                          method="post" enctype="multipart/form-data">

                                        <input type="hidden" name="assignmentId" value="@assignment.Id" />

                                        <div class="mb-2">
                                            <label class="fw-bold">Upload Solution File</label>
                                            <input type="file" name="solutionFile" class="form-control" required />
                                        </div>

                                        <button type="submit" class="btn btn-success btn-sm">
                                            Submit Solution
                                        </button>
                                    </form>
                                }
                            }


                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <!--==============================================================================================-->
    <!--------------------------------- Quizzes Section --------------------------->
    <h4 class="mb-3 mt-4">Quizzes</h4>

    @if (Model.Quizzes == null || !Model.Quizzes.Any())
    {
        <div class="alert alert-warning">
            No Quizzes added yet.
        </div>
    }
    else
    {
        <div class="accordion" id="quizzesAccordion">

            @foreach (var quiz in Model.Quizzes)
            {
                <div class="accordion-item mb-2 shadow-sm">

                    <h2 class="accordion-header" id="quizHeading-@quiz.Id">
                        <button class="accordion-button collapsed fw-bold"
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#quizCollapse-@quiz.Id">
                            Quiz: @quiz.Title
                        </button>
                    </h2>

                    <div id="quizCollapse-@quiz.Id"
                         class="accordion-collapse collapse"
                         data-bs-parent="#quizzesAccordion">

                        <div class="accordion-body">

                            <p><strong>Start:</strong> @quiz.StartTime</p>
                            <p><strong>End:</strong> @quiz.EndTime</p>
                            <p><strong>Max Degree:</strong> @quiz.TotalDegree</p>

                            @if (User.IsInRole("Instructor"))
                            {
                                <div class="mt-3 d-flex justify-content-end">
                                    <a asp-controller="Quiz"
                                       asp-action="UpdateQuiz"
                                       asp-route-quizId="@quiz.Id"
                                       class="btn btn-primary mt-3 me-2">
                                        Update Quiz
                                    </a>

                                    <a asp-controller="Quiz"
                                       asp-action="DeleteQuiz"
                                       asp-route-quizId="@quiz.Id"
                                       class="btn btn-danger mt-3 me-2"
                                       onclick="return confirm('Are you sure you want to delete this quiz?');">
                                        Delete Quiz
                                    </a>
                                </div>

 
                            }

                            @if (User.IsInRole("Student"))
                            {
                                DateTime now = DateTime.Now;
                                QuizSubmission? submission = quiz.QuizSubmissions
                                .FirstOrDefault(s => s.ApplicationUserId == User.FindFirstValue(ClaimTypes.NameIdentifier) && s.QuizId == quiz.Id);

                                if (submission != null)
                                {
                                    <p class="text-success fw-bold mt-3">
                                        <i class="bi bi-check-circle-fill"></i>
                                        You have submitted this quiz.
                                    </p>
                                    <p class="text-success fw-bold mt-3">
                                        ✅ Your Degree: @submission.Degree / @quiz.TotalDegree
                                    </p>
                                }
                                else if (now < quiz.StartTime)
                                {
                                    <p class="text-warning fw-bold mt-3">
                                        ⏳ Quiz not Started yet.
                                    </p>
                                }
                                else if (now > quiz.EndTime)
                                {
                                    <p class="text-danger fw-bold mt-3">
                                        🚫 Quiz closed.
                                    </p>
                                }
                                else
                                {
                                    <a asp-controller="Quiz"
                                       asp-action="StartQuiz"
                                       asp-route-quizId=@quiz.Id
                                       class="btn btn-success mt-3 me-2">
                                        Start Quiz
                                    </a>
                                }
                            }

                        </div>
                    </div>
                </div>
            }

        </div>
    }

</div>



