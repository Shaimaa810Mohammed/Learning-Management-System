@{
    ViewData["Title"] = "All Courses";
}

@model List<Course>

@if (User.IsInRole("Instructor"))
{
    <a class="btn btn-primary m-3" asp-controller="Course" asp-action="CreateCourse">Create Course</a>
}


<div class="container mt-4">
    <h2 class="mb-4">My Courses</h2>

    <div class="row">
        @foreach (var course in Model)
        {
            <div class="col-md-4 col-sm-6 mb-4">
                <div class="card shadow h-100">

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title text-center">@course.Title</h5>

                        <p class="card-text text-muted">
                            @course.Description
                        </p>

                        <p class="text-muted mb-1">
                            <i class="bi bi-clock"></i> Duration: @course.duration Hours
                        </p>

                        <div class="mt-auto">
                            <a asp-controller="Course"
                               asp-action="Details"
                               asp-route-id="@course.Id"
                               class="btn btn-primary w-100">
                                View Details
                            </a>
                        </div>
                    </div>

                </div>
            </div>
        }
    </div>
</div>
