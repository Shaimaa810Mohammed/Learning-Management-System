@using LearningManagementSystem.ViewModels
@{
    ViewData["Title"] = "Login";
}

@model LoginUserViewModel

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <!-- Card frame starts -->
            <div class="card shadow p-4">
                <div class="card-body">
                    <h5 class="card-title mb-4 text-center">Login</h5>
                    <form asp-controller="Account" asp-action="Login" method="post">
                        <div asp-validation-summary="All" class="text-danger"></div>
                        <div class="form-group mb-3">
                            <label asp-for="UserName"></label>
                            <input class="form-control" asp-for="UserName">
                            <span asp-validation-for="UserName" class="text-danger"></span>
                        </div>
                           
                        <div class="form-group mb-3">
                            <label asp-for="Password"></label>
                            <div class="password-wrapper" style="position: relative;">
                                <input id="password" type="password" class="form-control" asp-for="Password">
                                <i id="togglePassword" class="fa-solid fa-eye" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); cursor: pointer;"></i>
                            </div>
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <input class="form-check-input" asp-for="RememberMe">
                            <label class="form-check-label" asp-for="RememberMe"></label>
                            <span asp-validation-for="RememberMe" class="text-danger"></span>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Login</button>
                        <a asp-action="ForgetPassword" asp-controller="Account">Forget Password ?</a>
                    </form>
                </div>
            </div>
            <!-- Card frame ends -->
            @* <div><a asp-action="RegisterForm" asp-controller="Account" class="btn btn-primary m-3">Create User</a></div> *@
        </div>
    </div>
</div>

<partial name="_ValidationScriptsPartial" />
<partial name="_TogglePassword" />


