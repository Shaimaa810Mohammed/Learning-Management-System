@using LearningManagementSystem.ViewModels
@{
    ViewData["Title"] = "Update Quiz";
    int quizId = (int)ViewBag.quizId;
    List<Question> courseQuestions = (List<Question>)ViewBag.courseQuestions;
    List<int> quizQuestionsIds = (List<int>)ViewBag.quizQuestionsIds;
}

@model QuizViewModel

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <!-- Card frame starts -->
            <div class="card shadow p-4">
                <div class="card-body">
                    <h5 class="card-title mb-4 text-center">Update Quiz</h5>
                    <form asp-controller="Quiz" asp-action="SaveUpdate" asp-route-quizId=@quizId method="post">
                        <div asp-validation-summary="All" class="text-danger"></div>

                        <input type="hidden" asp-for="CourseId"/>

                        <div class="form-group mb-3">
                            <label asp-for="Title"></label>
                            <input class="form-control" asp-for="Title">
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="StartTime"></label>
                            <input class="form-control" asp-for="StartTime">
                            <span asp-validation-for="StartTime" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="EndTime"></label>
                            <input class="form-control" asp-for="EndTime">
                            <span asp-validation-for="EndTime" class="text-danger"></span>
                        </div>

                        <!--==========================================================    -->

                        <hr />
                        <h6 class="fw-bold mb-3">Select Questions</h6>

                        @if (courseQuestions == null || !courseQuestions.Any())
                        {
                            <div class="alert alert-warning">
                                No questions available for this course.
                            </div>
                        }
                        else
                        {
                            <div class="list-group">
                                @foreach (var q in courseQuestions)
                                {
                                    bool isChecked = quizQuestionsIds.Contains(q.Id);
                                    <label class="list-group-item d-flex align-items-start gap-2">
                                        <input type="checkbox"
                                               name="SelectedQuestionsIds"
                                               value=@q.Id
                                               class="form-check-input mt-1"
                                               @(isChecked ? "checked" : "") />

                                        <div>
                                            <strong>@q.QuestionType</strong>
                                            <p class="mb-1">@q.QuestionText</p>
                                        </div>
                                    </label>
                                }
                            </div>
                        }

                        <button type="submit" class="btn btn-primary w-100">Update</button>
                    </form>
                </div>
            </div>
            <!-- Card frame ends -->
        </div>
    </div>
</div>

<partial name="_ValidationScriptsPartial" />