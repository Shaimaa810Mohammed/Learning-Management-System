@using LearningManagementSystem.ViewModels
@model StartQuizViewModel

@{
    ViewData["Title"] = "Start Quiz";
}

<h2 class="text-center mb-4">Quiz</h2>

<form id="quizForm" method="post" asp-action="SubmitQuiz" asp-controller="Quiz">
    <input type="hidden" name="QuizId" value="@Model.QuizId" />
    <input type="hidden" name="StudentId" value="@Model.StudentId" />
    <input type="hidden" name="EndTime" value="@Model.EndTime" />

    @for (int i = 0; i < Model.Questions.Count; i++)
    {
        <div class="card mb-3 p-3 shadow">
            <h5>@(i + 1)- @Model.Questions[i].QuestionText</h5>
            <input type="hidden" name="QuestionsId[@i]" value="@Model.Questions[i].Id" />
            @foreach (var option in Model.Questions[i].AnswerOptions)
            {
                <div class="form-check">
                    <input class="form-check-input"
                           type="radio"
                           name="StudentAnswers[@i]"
                           value="@option"
                           required />

                    <label class="form-check-label">
                        @option
                    </label>
                </div>
            }
        </div>
    }

    <button type="submit" class="btn btn-primary w-100">Submit Quiz</button>
</form>





