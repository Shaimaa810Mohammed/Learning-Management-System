@using LearningManagementSystem.ViewModels
@{
    ViewData["Title"] = "Create Assignment";
}

@model AssignmentViewModel


<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <!-- Card frame starts -->
            <div class="card shadow p-4">
                <div class="card-body">
                    <h5 class="card-title mb-4 text-center">Create Assignment</h5>
                    <form asp-controller="Assignment" asp-action="SaveCreate" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="All" class="text-danger"></div>

                        <input type="hidden" asp-for="CourseId" />

                        <div class="form-group mb-3">
                            <label asp-for="Title"></label>
                            <input class="form-control" asp-for="Title">
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="StartTime"></label>
                            <input class="form-control" asp-for="StartTime" value="@Model?.StartTime">
                            <span asp-validation-for="StartTime" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="EndTime"></label>
                            <input class="form-control" asp-for="EndTime" value="@Model?.EndTime">
                            <span asp-validation-for="EndTime" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="MaxDegree"></label>
                            <input class="form-control" asp-for="MaxDegree" value="@Model?.MaxDegree">
                            <span asp-validation-for="MaxDegree" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="AssignmentFile"></label>
                            <input class="form-control" asp-for="AssignmentFile">
                            <span asp-validation-for="AssignmentFile" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Create</button>
                    </form>
                </div>
            </div>
            <!-- Card frame ends -->
        </div>
    </div>
</div>

<partial name="_ValidationScriptsPartial" />




