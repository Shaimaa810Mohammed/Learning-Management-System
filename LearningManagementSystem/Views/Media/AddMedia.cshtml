@{
    ViewData["Title"] = "Add Media";
    int lessonId = (int)ViewBag.lessonId;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <!-- Card frame starts -->
            <div class="card shadow p-4">
                <div class="card-body">
                    <h5 class="card-title mb-4 text-center">Create Lesson</h5>
                    <form asp-controller="Media" asp-action="SaveMedia" asp-route-lessonId=@lessonId method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="All" class="text-danger"></div>

                        <div class="form-group mb-3">
                            <label>Add File</label>
                            <input type="file" class="form-control" name="mediaFile" />
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Add</button>
                    </form>
                </div>
            </div>
            <!-- Card frame ends -->
        </div>
    </div>
</div>

<partial name="_ValidationScriptsPartial" />


