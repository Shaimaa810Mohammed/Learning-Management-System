@model List<Course>
@{
    ViewData["Title"] = "Select Course";
    SelectList courses = new SelectList(Model, "Id", "Title");
}

<a class="btn btn-primary m-3" asp-controller="Question" asp-action="CreateQuestion">Create Question</a>


<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <!-- Card frame starts -->
            <div class="card shadow p-4">
                <div class="card-body">
                    <h5 class="card-title mb-4 text-center">Select Course</h5>
                    <form asp-controller="Question" asp-action="Index" method="post">
                        <div asp-validation-summary="All" class="text-danger"></div>

                        <div class="form-group mb-3">
                            <label>Select Course To view its Questions</label>
                            <select class="form-control" name="courseId" asp-items="courses"></select>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Display Questions</button>
                    </form>
                </div>
            </div>
            <!-- Card frame ends -->
        </div>
    </div>
</div>

<partial name="_ValidationScriptsPartial" />

