@{
    ViewData["Title"] = "Create Lesson";
}

@using LearningManagementSystem.ViewModels
@model CreateLessonViewModel

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <!-- Card frame starts -->
            <div class="card shadow p-4">
                <div class="card-body">
                    <h5 class="card-title mb-4 text-center">Create Lesson</h5>
                    <form asp-controller="Lesson" asp-action="SaveLesson" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="All" class="text-danger"></div>

                        <input type="hidden" asp-for="CourseId" />

                        <div class="form-group mb-3">
                            <label asp-for="Title"></label>
                            <input class="form-control" asp-for="Title">
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="MediaFiles"></label>
                            <input type="file" multiple class="form-control" asp-for="MediaFiles" />
                            <span asp-validation-for="MediaFiles" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Create</button>
                    </form>
                </div>
            </div>
            <!-- Card frame ends -->
        </div>
    </div>
</div>

<partial name="_ValidationScriptsPartial" />


