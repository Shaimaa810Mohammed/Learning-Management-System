@using LearningManagementSystem.ViewModels
@{
    ViewData["Title"] = "Update Lesson";
}

@model UpdateLessonViewModel

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <!-- Card frame starts -->
            <div class="card shadow p-4">
                <div class="card-body">
                    <h5 class="card-title mb-4 text-center">Update Lesson</h5>
                    <form asp-controller="Lesson" asp-action="SaveUpdate" method="post">
                        <div asp-validation-summary="All" class="text-danger"></div>

                        <input type="hidden" asp-for="LessonId" />

                        <div class="form-group mb-3">
                            <label asp-for="Title"></label>
                            <input class="form-control" asp-for="Title">
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Update</button>
                    </form>
                </div>
            </div>
            <!-- Card frame ends -->
        </div>
    </div>
</div>

<partial name="_ValidationScriptsPartial" />
